<?xml version="1.0" encoding="UTF-8"?>
<window>
	<controls>
		<!-- FUNDAL -->
		<control type="group">
			<animation effect="zoom" start="0" end="100" time="200"
			           center="auto" tween="quadratic" easing="out">WindowOpen</animation>
			<control type="image">
				<left>0</left><top>0</top>
				<width>1920</width><height>1080</height>
				<texture>black.png</texture>
			</control>
			<control type="image">
				<left>0</left><top>0</top>
				<width>1920</width><height>1080</height>
				<texture>$INFO[Window.Property(mrsp.fanart)]</texture>
				<animation effect="fade" start="0" end="25" time="0" tween="sine">WindowOpen</animation>
			</control>
		</control>

		<!-- HEADER -->
		<control type="group">
			<animation effect="fade" start="0" end="100" delay="400" time="500">WindowOpen</animation>
			<control type="image">
				<left>35</left><top>15</top>
				<width>50</width><height>50</height>
				<aspectratio aligny="top">keep</aspectratio>
				<texture>$INFO[Window.Property(mrsp.icon)]</texture>
			</control>
			<control type="label">
				<left>95</left><top>8</top>
				<width max="750">auto</width><height>30</height>
				<font>font14</font>
				<textcolor>FFFFFFFF</textcolor>
				<align>left</align><aligny>center</aligny>
				<label>[UPPERCASE][B]$INFO[Window.Property(mrsp.title)][/B][/UPPERCASE]</label>
			</control>
			<control type="label">
				<left>95</left><top>40</top>
				<width max="1200">auto</width><height>28</height>
				<font>font13</font>
				<textcolor>FFFFFFFF</textcolor>
				<align>left</align><aligny>center</aligny>
				<label>[COLOR FFFF00FF][B]4K: $INFO[Window.Property(mrsp.count_4k)][/B][/COLOR]  [COLOR FF7CFC00][B]1080p: $INFO[Window.Property(mrsp.count_1080p)][/B][/COLOR]  [COLOR FFFFD700][B]720p: $INFO[Window.Property(mrsp.count_720p)][/B][/COLOR]  [COLOR FFD3D3D3][B]SD: $INFO[Window.Property(mrsp.count_sd)][/B][/COLOR]  |  [B]$INFO[Window.Property(mrsp.total_results)] Rezultate[/B]</label>
			</control>
		</control>

		<!-- POSTER + PLOT -->
		<control type="group">
			<animation type="WindowOpen" reversible="false">
				<effect type="fade" start="0" end="100" time="250"
				        tween="sine" delay="350" easing="in" />
				<effect type="slide" start="500" end="0" time="250"
				        center="auto" delay="350" tween="quadratic" easing="out" />
			</animation>
			<control type="image">
				<left>1395</left><top>100</top>
				<width>486</width><height>729</height>
				<aspectratio aligny="top">keep</aspectratio>
				<texture background="true">$INFO[Window.Property(mrsp.poster)]</texture>
			</control>
			<control type="textbox">
				<left>1395</left><top>845</top>
				<width>486</width><height>195</height>
				<font>font12</font>
				<align>justify</align><aligny>top</aligny>
				<label>$INFO[Window.Property(mrsp.plot)]</label>
				<textcolor>FFFFFFFF</textcolor>
				<autoscroll time="2000" delay="5500" repeat="5000"></autoscroll>
			</control>
		</control>

		<!-- LISTA SURSE -->
		<control type="group">
			<animation type="WindowOpen" reversible="false">
				<effect type="fade" start="0" end="100" time="400"
				        tween="sine" delay="200" easing="in" />
				<effect type="slide" start="-1300" end="0" time="400"
				        center="auto" tween="quadratic" delay="200" easing="out" />
			</animation>

			<control type="fixedlist" id="2000">
				<pagecontrol>2060</pagecontrol>
				<left>35</left><top>85</top>
				<width>1300</width><height>960</height>
				<onup>2000</onup>
				<ondown>2000</ondown>
				<onright>2060</onright>
				<scrolltime tween="sine">350</scrolltime>
				<orientation>Vertical</orientation>
				<focusposition>3</focusposition>
				<movement>4</movement>

<!-- ══════════════════════════ -->
				<!-- ITEM NORMAL               -->
				<!-- ══════════════════════════ -->
				<itemlayout height="120" width="1300">
					<control type="image">
						<left>0</left><top>15</top>
						<width>1300</width><height>110</height>
						<texture colordiffuse="BF4a4347">white.png</texture>
					</control>
					<!-- COLOANA STÂNGA: Calitate + Provider / Icon Paginare -->
					<control type="group">
						<left>0</left><top>15</top>
						<width>200</width><height>110</height>
						<!-- Calitate — Apare doar daca NU e paginare -->
						<control type="label">
							<left>0</left><top>5</top>
							<width>200</width><height>55</height>
							<font>font30</font>
							<align>center</align><aligny>center</aligny>
							<label>[COLOR $INFO[ListItem.Property(mrsp.highlight)]][B]$INFO[ListItem.Property(mrsp.quality)][/B][/COLOR]</label>
							<visible>String.IsEmpty(ListItem.Property(mrsp.is_next))</visible>
						</control>
						<!-- Provider — Apare doar daca NU e paginare -->
						<control type="label">
							<left>0</left><top>62</top>
							<width>200</width><height>30</height>
							<font>font12</font>
							<align>center</align><aligny>center</aligny>
							<label>[COLOR $INFO[ListItem.Property(mrsp.highlight)]][B]$INFO[ListItem.Property(mrsp.provider)][/B][/COLOR]</label>
							<visible>String.IsEmpty(ListItem.Property(mrsp.is_next))</visible>
						</control>
						<!-- Iconita Sageata — Apare DOAR la paginare -->
						<control type="image">
							<left>75</left>
							<top>35</top>
							<width>50</width><height>50</height>
							<aspectratio>keep</aspectratio>
							<texture>$INFO[ListItem.Property(mrsp.provider_icon)]</texture>
							<visible>!String.IsEmpty(ListItem.Property(mrsp.is_next))</visible>
						</control>
					</control>
					<!-- Nume torrent -->
					<control type="label">
						<top>22</top><left>210</left>
						<width max="1070">auto</width><height>30</height>
						<font>font14</font>
						<textcolor>FF9c9a9b</textcolor>
						<align>left</align><aligny>center</aligny>
						<label>$INFO[ListItem.Property(mrsp.count)]  $INFO[ListItem.Property(mrsp.name)]</label>
					</control>
					<!-- Info line (Atmos, Remux, etc) -->
					<control type="label">
						<top>62</top><left>210</left>
						<width max="1070">auto</width><height>40</height>
						<font>font13</font>
						<textcolor>FF9c9a9b</textcolor>
						<align>left</align><aligny>center</aligny>
						<label>$INFO[ListItem.Property(mrsp.info_line)]</label>
					</control>
				</itemlayout>

				<!-- ══════════════════════════ -->
				<!-- ITEM FOCALIZAT (SELECTAT) -->
				<!-- ══════════════════════════ -->
				<focusedlayout height="120" width="1300">
					<control type="group">
						<animation type="Focus">
							<effect type="zoom" start="100" end="102" time="100" tween="sine" easing="inout" center="650,60" />
						</animation>
						<control type="image">
							<left>0</left><top>15</top>
							<width>1300</width><height>110</height>
							<texture colordiffuse="FF4a4347">white.png</texture>
						</control>
						<control type="image">
							<left>0</left><top>15</top>
							<width>1300</width><height>110</height>
							<texture flipx="true" colordiffuse="$INFO[ListItem.Property(mrsp.highlight)]">gradient-diffuse-horizontal.png</texture>
						</control>
						<!-- COLOANA STÂNGA: Calitate + Provider / Icon Paginare (IDEM ca sus) -->
						<control type="group">
							<left>0</left><top>15</top>
							<width>200</width><height>110</height>
							<control type="label">
								<left>0</left><top>5</top>
								<width>200</width><height>55</height>
								<font>font30</font>
								<align>center</align><aligny>center</aligny>
								<label>[B]$INFO[ListItem.Property(mrsp.quality)][/B]</label>
								<visible>String.IsEmpty(ListItem.Property(mrsp.is_next))</visible>
							</control>
							<control type="label">
								<left>0</left><top>62</top>
								<width>200</width><height>30</height>
								<font>font12</font>
								<align>center</align><aligny>center</aligny>
								<label>[B]$INFO[ListItem.Property(mrsp.provider)][/B]</label>
								<visible>String.IsEmpty(ListItem.Property(mrsp.is_next))</visible>
							</control>
							<control type="image">
								<left>75</left>
								<top>35</top>
								<width>50</width><height>50</height>
								<aspectratio>keep</aspectratio>
								<texture>$INFO[ListItem.Property(mrsp.provider_icon)]</texture>
								<visible>!String.IsEmpty(ListItem.Property(mrsp.is_next))</visible>
							</control>
						</control>
						<!-- Nume torrent focalizat -->
						<control type="label">
							<top>22</top><left>210</left>
							<width max="1070">auto</width><height>30</height>
							<font>font14</font>
							<textcolor>FFFFFFFF</textcolor>
							<align>left</align><aligny>center</aligny>
							<label>$INFO[ListItem.Property(mrsp.count)]  $INFO[ListItem.Property(mrsp.name)]</label>
						</control>
						<!-- Info line focalizat -->
						<control type="label">
							<top>62</top><left>210</left>
							<width max="1070">auto</width><height>40</height>
							<font>font13</font>
							<textcolor>FFFFFFFF</textcolor>
							<align>left</align><aligny>center</aligny>
							<label>$INFO[ListItem.Property(mrsp.info_line)]</label>
						</control>
					</control>
				</focusedlayout>
			</control>

			<!-- FLAG pe scrollbar -->
			<control type="image">
				<left>1215</left><top>505</top>
				<width>120</width><height>60</height>
				<align>center</align><aligny>center</aligny>
				<aspectratio>keep</aspectratio>
				<texture colordiffuse="$INFO[Container(2000).ListItem.Property(mrsp.highlight)]">$INFO[Container(2000).ListItem.Property(mrsp.quality_icon)]</texture>
				<visible>Control.HasFocus(2060)</visible>
				<animation effect="slide" start="20,0" end="0,0" time="250">Visible</animation>
			</control>

			<!-- SCROLLBAR -->
			<control type="scrollbar" id="2060">
				<top>100</top><left>1360</left>
				<width>15</width><height>945</height>
				<onleft>2000</onleft>
				<onright>2000</onright>
				<texturesliderbackground colordiffuse="FF302F2F">white.png</texturesliderbackground>
				<texturesliderbar colordiffuse="FF555556">white.png</texturesliderbar>
				<texturesliderbarfocus
					colordiffuse="$INFO[Container(2000).ListItem.Property(mrsp.highlight)]">white.png</texturesliderbarfocus>
				<showonepage>false</showonepage>
				<orientation>vertical</orientation>
				<visible>Control.IsVisible(2000)</visible>
			</control>
		</control>

		<control type="label">
			<left>0</left><top>0</top>
			<width>1920</width><height>1080</height>
			<font>font14</font>
			<textcolor>FF9c9a9b</textcolor>
			<align>center</align><aligny>center</aligny>
			<label>Nu s-au găsit rezultate</label>
			<visible>Integer.IsEqual(Container(2000).NumItems,0)</visible>
		</control>
	</controls>
</window>