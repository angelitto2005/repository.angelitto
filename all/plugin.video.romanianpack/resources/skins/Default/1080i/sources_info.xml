<?xml version="1.0" encoding="UTF-8"?>
<!-- Premium Source Info Dialog - MRSP Lite -->
<window type="dialog">
    <defaultcontrol always="true">1</defaultcontrol>
    <coordinates>
        <left>0</left>
        <top>0</top>
    </coordinates>
    <controls>
        <!-- Background Overlay (Dark Gray) -->
        <control type="image">
            <width>1920</width>
            <height>1080</height>
            <texture>black.png</texture>
            <colordiffuse>AA1A1A1A</colordiffuse> 
            <animation effect="fade" start="0" end="100" time="200">WindowOpen</animation>
            <animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
        </control>

        <!-- Main Dialog Box -->
        <control type="group">
            <left>310</left>
            <top>120</top>
            <width>1300</width>
            <height>840</height>
            <animation effect="zoom" start="90" end="100" center="auto" time="250" tween="quadratic" easing="out">WindowOpen</animation>
            <animation effect="zoom" start="100" end="90" center="auto" time="200" tween="quadratic" easing="in">WindowClose</animation>

            <!-- Box Background (LIGHT GRAY) -->
            <control type="image">
                <width>1300</width>
                <height>840</height>
                <texture border="30">circle.png</texture>
                <colordiffuse>FF555555</colordiffuse>
            </control>
            
            <control type="image">
                <left>10</left>
                <top>10</top>
                <width>1280</width>
                <height>820</height>
                <texture border="30">circle.png</texture>
                <colordiffuse>FF333333</colordiffuse>
            </control>

            <!-- Header Content -->
            <control type="group">
                <left>50</left>
                <top>50</top>
                
                <!-- Poster -->
                <control type="image">
                    <width>280</width>
                    <height>420</height>
                    <aspectratio aligny="top">keep</aspectratio>
                    <texture diffuse="thumbs/movieposter_mask.png">$INFO[Window.Property(mrsp.poster)]</texture>
                </control>

                <!-- Fanart (Clear) -->
                <control type="image">
                    <left>260</left>
                    <width>1000</width>
                    <height>420</height>
                    <texture diffuse="thumbs/fanart_mask.png">$INFO[Window.Property(mrsp.fanart)]</texture>
                    <aspectratio aligny="top">keep</aspectratio>
                </control>
            </control>

            <!-- Metadata Section (Non-scrolling) -->
            <control type="group">
                <left>70</left>
                <top>490</top>
                <width>1160</width>

                <!-- Left Column: Details -->
                <control type="grouplist">
                    <width>750</width>
                    <height>230</height>
                    <itemgap>2</itemgap>
                    <orientation>vertical</orientation>

                    <!-- DETAILS -->
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[UPPERCASE][COLOR $INFO[Window.Property(mrsp.highlight)]][B]SITE / TRACKER:[/B][/COLOR] $INFO[Window.Property(mrsp.provider)][/UPPERCASE]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[UPPERCASE][COLOR $INFO[Window.Property(mrsp.highlight)]][B]SURSĂ:[/B][/COLOR] $INFO[Window.Property(mrsp.indexer)][/UPPERCASE]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[UPPERCASE][COLOR $INFO[Window.Property(mrsp.highlight)]][B]SERVER / CACHE:[/B][/COLOR] $INFO[Window.Property(mrsp.server_label)][/UPPERCASE]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[UPPERCASE][COLOR $INFO[Window.Property(mrsp.highlight)]][B]SEEDERS / STATUS:[/B][/COLOR] $INFO[Window.Property(mrsp.status_clean)][/UPPERCASE]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[UPPERCASE][COLOR $INFO[Window.Property(mrsp.highlight)]][B]MĂRIME:[/B][/COLOR] [COLOR cyan][B]$INFO[Window.Property(mrsp.size)][/B][/COLOR][/UPPERCASE]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[UPPERCASE][COLOR $INFO[Window.Property(mrsp.highlight)]][B]CODEC / GRUP:[/B][/COLOR] $INFO[Window.Property(mrsp.codec)] | [COLOR FFFF69B4][B]$INFO[Window.Property(mrsp.group)][/COLOR][/B][/UPPERCASE]</label>
                    </control>
                </control>

                <!-- RELEASE NAME (Full Width Multi-line) -->
                <control type="textbox">
                    <top>240</top>
                    <width>1160</width>
                    <height>90</height>
                    <font>font14</font>
                    <align>left</align>
                    <label>[UPPERCASE][COLOR $INFO[Window.Property(mrsp.highlight)]][B]NUME FIȘIER:[/B][/COLOR] $INFO[Window.Property(mrsp.release_name)][/UPPERCASE]</label>
                    <textcolor>FFFFFFFF</textcolor>
                </control>

                <!-- Right Column: Quality & Tags (Lărgit și Aliniat Perfect) -->
                <control type="group">
                    <left>720</left> <!-- Mutat la dreapta ca să nu se mai suprapună cu stânga -->
                    <control type="image">
                        <left>20</left>
                        <top>10</top>
                        <width>400</width>
                        <height>100</height>
                        <aspectratio>keep</aspectratio>
                        <texture>$INFO[Window.Property(mrsp.quality_icon)]</texture>
                        <colordiffuse>$INFO[Window.Property(mrsp.highlight)]</colordiffuse>
                    </control>
                    <control type="group">
                        <top>120</top>
                        <left>20</left>
                        <control type="label">
                            <width>400</width> <!-- Lățime mărită -->
                            <height>25</height>
                            <font>font12</font>
                            <align>center</align>
                            <label>[COLOR gray]ATRIBUTE[/COLOR]</label>
                        </control>
                        <control type="textbox">
                            <top>30</top> 
                            <width>400</width> <!-- Lățime mărită -->
                            <height>110</height> <!-- Înălțime mărită de la 80 la 110 -->
                            <font>font12</font>
                            <align>center</align>
                            <label>[UPPERCASE][B]$INFO[Window.Property(mrsp.tags)][/B][/UPPERCASE]</label>
                            <textcolor>orange</textcolor>
                        </control>
                    </control>
                </control>
            </control>
        </control>
    </controls>
</window>