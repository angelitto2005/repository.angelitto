		<setting id="color_720p" type="action" label="  720p Color" subsetting="true" visible="eq(-3,3)" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=color_picker&amp;setting=color_720p)"/>
		<setting id="color_sd" type="action" label="  SD Color" subsetting="true" visible="eq(-4,3)" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=color_picker&amp;setting=color_sd)"/>
    </category>
    
