		<setting type="lsep" label="Plot"/>
		<setting id="plot_language" type="text" label="Language for plot, poster, logo, fanart (en, ro, enro, de, etc.)" default="enro"/>
		<setting id="page_limit" type="enum" label="Items per page" values="20|40|60|80|100" default="0"/>
		<setting type="lsep" label="TV Shows Settings"/>
		<setting id="auto_scrape_next_episode" type="bool" label="[B][COLOR FFCCCCFF]Auto-Play [COLOR FF33CCFF]Next Episode[/COLOR][/B]" default="true" />		
		<setting id="upnext_show_future" type="bool" label="[B][COLOR FF33CCFF]Up Next:[/COLOR][/B] Show future episodes (over 7 days / TBA)" default="false"/>
        <setting id="episodes_art" type="enum" label="Episode Images (Icon + Background)" values="Thumb + Fanart (Hibrid)|Thumb + Thumb|Poster + Fanart|Poster + Thumb" default="0"/>
		<setting id="skin_type" type="enum" label="Skin Compatibility (Fix Art/Thumbnails)" values="[B][COLOR FF6AFB92]Estuary (Standard)[/COLOR][/B]|[B][COLOR FF6AFB92]Arctic Fuse 3 (Modern)[/COLOR][/B]" default="0"/>
		<setting id="show_motto_genre" type="bool" label="Show Motto + Genre above description" default="true"/>
		
		<setting type="lsep" label="AutoPlay [COLOR gray]Windows[/COLOR] vs [COLOR gray]Android[/COLOR]"/>
		<setting id="auto_play" type="bool" label="Auto-play the most recommended source." default="false"/>
        <setting id="autoplay_profile" type="enum" label="System and Quality" values="Windows 1080p|Android 4K|Android 1080p" default="0" visible="eq(-1,true)"/>
		<setting type="lsep" label="Download"/>
		<setting id="show_download_progress" type="bool" label="Show info panel (top-right) during download" default="true"/>
		<setting type="lsep" label="Colors"/>
		<setting id="pov_theme" type="enum" label="Source window appearance" values="Multicolor|Simple|Mono|Custom" default="0"/>
		<setting id="color_4k" type="action" label="  4K Color" subsetting="true" visible="eq(-1,3)" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=color_picker&amp;setting=color_4k)"/>
