<?xml version="1.0" encoding="utf-8"?>
<settings>
    <!-- 1. GENERAL -->
    <category label="General">
		<setting type="lsep" label="Context Info"/>
        <setting id="enable_global_context" type="bool" label="Activează Meniul Contextual [B][COLOR FF6AFB92]TMDb INFO[/COLOR][/B]" default="true"/>
        <setting id="enable_extended_context" type="bool" label="Activează Meniul Contextual [B][COLOR FF33CCFF]TMDb Extended Info[/COLOR][/B]" default="true"/>
		<setting type="lsep" label="Plot"/>
		<setting id="plot_language" type="enum" label="Limba descrierii (Plot)" values="English|Română" default="0"/>
		<setting type="lsep" label="AutoPlay"/>
        <setting id="auto_play" type="bool" label="Activează Auto Play" default="false"/>
        <setting id="autoplay_profile" type="enum" label="Sistem și Calitate" values="Windows 1080p|Android 4K|Android 1080p" default="0" visible="eq(-1,true)"/>
		<setting type="lsep" label="Download"/>
		<setting id="show_download_progress" type="bool" label="Afișează panou informativ (dreapta-sus) în timpul descărcării" default="true"/>
		<setting type="lsep" label="Culori"/>
		<setting id="pov_theme" type="enum" label="Aspect fereastră surse" values="Multicolor|Simplu" default="0"/>
    </category>
    
	<!-- 2. PROVIDERI -->
    <category label="Provideri">
		<setting type="lsep" label="Smart Cache"/>
		<setting id="use_cache_sources" type="bool" label="[B][COLOR FFFFD700]Cache Sources (Smart Retry)[/COLOR][/B]" default="true"/>
        <setting id="cache_sources_duration" type="slider" label="Durată Cache (Ore)" default="24" min="1" max="168" option="int" subsetting="true" visible="eq(-1,true)"/>
		
        <setting type="lsep" label="Provideri"/>
        <setting id="use_sooti" type="bool" label="Activează [B][COLOR FF00FA9A]SlowNow[/COLOR][/B]" default="true"/>
        <setting id="use_nuviostreams" type="bool" label="Activează [B][COLOR FF00FA9A]NotNow[/COLOR][/B]" default="false"/>
        <setting id="use_webstreamr" type="bool" label="Activează [B][COLOR FF00FA9A]WebNow[/COLOR][/B]" default="true"/>
		<setting id="use_vixsrc" type="bool" label="Activează [B][COLOR FF00FA9A]VixSrc[/COLOR][/B]" default="true"/>
        <setting id="use_meowtv" type="bool" label="Activează [B][COLOR FF00FA9A]MeowTV (VFlix)[/COLOR][/B]" default="true"/>
        <setting id="use_streamvix" type="bool" label="Activează [B][COLOR FF00FA9A]StreamNow[/COLOR][/B]" default="true"/>
		<setting id="use_vega" type="bool" label="Activează Vega" default="false" visible="false"/>
		<setting id="use_vidzee" type="bool" label="Activează Vidzee" default="false" visible="false"/>
        <setting id="use_rogflix" type="bool" label="Activează Rogflix" default="false" visible="false"/>
		<setting id="use_hdhub4u" type="bool" label="Activează [B][COLOR FF00FA9A]HDHub4u (Hindi)[/COLOR][/B]" default="true" />
		<setting id="use_mkvcinemas" type="bool" label="Activează [B][COLOR FF00FA9A]MKVCinemas (Hindi)[/COLOR][/B]" default="false"/>
		<setting id="use_moviesdrive" type="bool" label="Activează [B][COLOR FF00FA9A]MoviesDrive (Hindi)[/COLOR][/B]" default="true" />
		<setting id="use_xdmovies" type="bool" label="Activează [B][COLOR FF00FA9A]SmileNow[/COLOR][/B]" default="false" visible="false"/>
		
        <setting type="lsep" label="Excluderi"/>
		<setting id="exclude_4k" type="bool" label="Exclude 4K / 2160p" default="false"/>
		<setting id="exclude_1080p" type="bool" label="Exclude 1080p" default="false"/>
		<setting id="exclude_720p" type="bool" label="Exclude 720p" default="false"/>
		<setting id="exclude_sd" type="bool" label="Exclude SD / 480p și mai jos" default="false"/>
		
		<setting type="lsep" label="Filtrare surse"/>
		<setting id="filter_duplicate_urls" type="bool" label="Filtrează sursele duplicate (același URL)" default="true"/>
        <setting id="source_sorting" type="enum" label="Prioritate Surse (Sortare)" values="Amestecate (Calitate > Mărime)|AIO Cached -> HTTP -> AIO Necached|AIO Cached + HTTP -> AIO Necached" default="0"/>
    </category>

	<!-- 3. AIO STREAMS -->
    <category label="[B][COLOR magenta]AIO Streams[/COLOR][/B]">
        <setting label="─── Configurare AIO Streams ───" type="lsep" />
        <setting id="use_aiostreams" type="bool" label="Activează [B][COLOR magenta]AIO Streams[/COLOR][/B]" default="true"/>
        <setting id="aiostreams_instance" type="enum" label="Instanță" default="0"
            values="Kuu-lection stable|Kuu-lection nightly|Viren070|Nhyira stable|Nhyira nightly|Midnight stable|Midnight nightly|Elfhosted|Custom" />

        <!-- 0: Kuu-lection Stable -->
        <setting id="aio_url.0" type="text" label="  URL" default="https://aiostreams.stremio.ru" enable="false" visible="eq(-1,0)" />
        <setting id="aio_uuid.0" type="text" label="  UUID" default="" option="hidden" visible="eq(-2,0)" />
        <setting id="aio_password.0" type="text" label="  Password" default="" option="hidden" visible="eq(-3,0)" />

        <!-- 1: Kuu-lection-nightly -->
        <setting id="aio_url.1" type="text" label="  URL" default="https://aiostreams-nightly.stremio.ru" enable="false" visible="eq(-4,1)" />
        <setting id="aio_uuid.1" type="text" label="  UUID" default="" option="hidden" visible="eq(-5,1)" />
        <setting id="aio_password.1" type="text" label="  Password" default="" option="hidden" visible="eq(-6,1)" />

        <!-- 2: Viren070 -->
        <setting id="aio_url.2" type="text" label="  URL" default="https://aiostreams.viren070.me" enable="false" visible="eq(-7,2)" />
        <setting id="aio_uuid.2" type="text" label="  UUID" default="" option="hidden" visible="eq(-8,2)" />
        <setting id="aio_password.2" type="text" label="  Password" default="" option="hidden" visible="eq(-9,2)" />

        <!-- 3: Nhyira stable -->
        <setting id="aio_url.3" type="text" label="  URL" default="https://aiostreams.fortheweak.cloud" enable="false" visible="eq(-10,3)" />
        <setting id="aio_uuid.3" type="text" label="  UUID" default="" option="hidden" visible="eq(-11,3)" />
        <setting id="aio_password.3" type="text" label="  Password" default="" option="hidden" visible="eq(-12,3)" />

        <!-- 4: Nhyira nightly -->
        <setting id="aio_url.4" type="text" label="  URL" default="https://aiostreams-nightly.fortheweak.cloud" enable="false" visible="eq(-13,4)" />
        <setting id="aio_uuid.4" type="text" label="  UUID" default="" option="hidden" visible="eq(-14,4)" />
        <setting id="aio_password.4" type="text" label="  Password" default="" option="hidden" visible="eq(-15,4)" />

        <!-- 5: Midnight stable -->
        <setting id="aio_url.5" type="text" label="  URL" default="https://aiostreamsfortheweebsstable.midnightignite.me" enable="false" visible="eq(-16,5)" />
        <setting id="aio_uuid.5" type="text" label="  UUID" default="" option="hidden" visible="eq(-17,5)" />
        <setting id="aio_password.5" type="text" label="  Password" default="" option="hidden" visible="eq(-18,5)" />

        <!-- 6: Midnight nightly -->
        <setting id="aio_url.6" type="text" label="  URL" default="https://aiostreamsfortheweebs.midnightignite.me" enable="false" visible="eq(-19,6)" />
        <setting id="aio_uuid.6" type="text" label="  UUID" default="" option="hidden" visible="eq(-20,6)" />
        <setting id="aio_password.6" type="text" label="  Password" default="" option="hidden" visible="eq(-21,6)" />

        <!-- 7: Elfhosted -->
        <setting id="aio_url.7" type="text" label="  URL" default="https://aiostreams.elfhosted.com" enable="false" visible="eq(-22,7)" />
        <setting id="aio_uuid.7" type="text" label="  UUID" default="" option="hidden" visible="eq(-23,7)" />
        <setting id="aio_password.7" type="text" label="  Password" default="" option="hidden" visible="eq(-24,7)" />

        <!-- 8: Custom -->
        <setting id="aio_url.8" type="text" label="  URL (custom)" default="" visible="eq(-25,8)" />
        <setting id="aio_uuid.8" type="text" label="  UUID" default="" option="hidden" visible="eq(-26,8)" />
        <setting id="aio_password.8" type="text" label="  Password" default="" option="hidden" visible="eq(-27,8)" />
    </category>
	

    <!-- 4. CONTURI -->
    <category label="Conturi">
        <setting type="lsep" label="Cont Trakt"/>
        <setting label="[B][COLOR pink]Conectare Trakt[/COLOR][/B]" type="action" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=trakt_auth)"/>
        <setting label="[B][COLOR red]Deconectare Trakt[/COLOR][/B]" type="action" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=trakt_revoke)"/>
        <setting label="Status:" type="text" default="Neconectat" id="trakt_status" enable="false"/>
        
	<setting type="lsep" label="Cont TMDb"/>
        <setting label="[B][COLOR FF00CED1]Conectare TMDb (v3)[/COLOR][/B]" type="action" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=tmdb_auth)"/>
        <setting label="[B][COLOR FF00CED1]Autorizare Seriale (v4)[/COLOR][/B]" type="action" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=tmdb_auth_v4_action)"/>
        <setting label="[B][COLOR red]Deconectare TMDb[/COLOR][/B]" type="action" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=tmdb_revoke)"/>
        <setting label="Status:" type="text" default="Neconectat" id="tmdb_status" enable="false"/>
		
        <setting type="lsep" label="Sincronizare"/>
        <setting label="[B][COLOR FF6698FF]Sincronizare Manuală[/COLOR][/B]" type="action" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=trakt_sync)"/>
        
    </category>

	<!-- 5. MY PLAYS (PLAYERE EXTERNE) -->
    <category label="[B][COLOR FFFF69B4]My Plays[/COLOR][/B]">
        <setting type="lsep" label="Alege ce playere apar în meniu"/>
        <setting id="use_pov" type="bool" label="Afișează [B][COLOR FFB041FF]POV[/COLOR][/B]" default="true"/>
        <setting id="use_salts" type="bool" label="Afișează [B][COLOR gold]SALTS[/COLOR][/B]" default="true"/>
        <setting id="use_fenlight" type="bool" label="Afișează [B][COLOR lightskyblue]Fen Light[/COLOR][/B]" default="true"/>
        <setting id="use_fen" type="bool" label="Afișează [B][COLOR blue]Fen[/COLOR][/B]" default="true"/>
        <setting id="use_magneto" type="bool" label="Afișează [B][COLOR red]Magneto[/COLOR][/B]" default="true"/>
        <setting id="use_luckodi" type="bool" label="Afișează [B][COLOR ff00fa9a]luc_[/COLOR]Kodi[/B]" default="true"/>
        <setting id="use_umbrella" type="bool" label="Afișează [B][COLOR FFE41B17]Umbrella[/COLOR][/B]" default="true"/>
        <setting id="use_elementum" type="bool" label="Afișează [B][COLOR FF786D5F]Elementum[/COLOR][/B]" default="true"/>
        <setting id="use_cinebox" type="bool" label="Afișează [B][COLOR FFA70D2A]CINEBOX[/COLOR][/B]" default="true"/>
        <setting id="use_seren" type="bool" label="Afișează [B][COLOR FF00BFFF]Seren[/COLOR][/B]" default="true"/>
        <setting id="use_mrsplite" type="bool" label="Afișează [B][COLOR orange]MRSP Lite[/COLOR][/B]" default="true"/>
        <setting id="use_tmdbhelper" type="bool" label="Afișează [B][COLOR gold]TMDb Helper[/COLOR][/B]" default="true"/>

        <!-- === BUTON EXPORT TMDB HELPER === -->
        <setting type="lsep" label="Integrare TMDb Helper"/>
        <setting id="export_json_player" type="action" label="Exportă [B][COLOR yellow]Playerul JSON[/COLOR][/B] în [B][COLOR blue]TMDb Helper[/COLOR][/B]" option="close" action="RunScript(special://home/addons/plugin.video.tmdbmovies/resources/lib/jsonplayer/export_player.py)" />
        <!-- =================================== -->
    </category>

    <!-- 6. SUBTITRĂRI -->
    <category label="Subtitrări">
		<setting type="lsep" label="Wyzie"/>
        <setting id="use_osv3_subs" type="bool" label="Activează căutare subtitrări" default="false"/>
        <setting id="osv3_langs" type="text" label="Limbi (separate prin virgulă, ex: ro,en)" default="ro"/>
    </category>

    <!-- 7. MENTENANȚĂ -->
    <category label="Mentenanță">
		<setting type="lsep" label="Log"/>
        <setting id="debug_enabled" type="bool" label="Activează Jurnalizare Detaliată (Debug)" default="true"/>
		<setting type="lsep" label="Cache"/>
        <setting label="Șterge Tot Cache-ul" type="action" action="RunPlugin(plugin://plugin.video.tmdbmovies/?mode=clear_all_cache)"/>
    </category>
</settings>