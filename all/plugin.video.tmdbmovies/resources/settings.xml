<?xml version="1.0" encoding="utf-8"?>
<settings>
    <!-- 1. GENERAL -->
    <category label="General">
		<setting type="lsep" label="Context Info"/>
        <setting id="enable_global_context" type="bool" label="Enable Context Menu [B][COLOR FF6AFB92]TMDb INFO[/COLOR][/B]" default="true"/>
