<?xml version="1.0" encoding="UTF-8"?>
<!-- Premium Source Info Dialog - Light Gray Premium Style -->
<window type="dialog">
    <defaultcontrol always="true">1</defaultcontrol>
    <coordinates>
        <left>0</left>
        <top>0</top>
    </coordinates>
    <controls>
        <!-- Background Overlay (Full Opaque) -->
        <control type="image">
            <width>1920</width>
            <height>1080</height>
            <texture>black.png</texture>
            <colordiffuse>FF000000</colordiffuse> 
            <animation effect="fade" start="0" end="100" time="200">WindowOpen</animation>
            <animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
        </control>

        <!-- Main Dialog Box -->
        <control type="group">
            <left>310</left>
            <top>120</top>
            <width>1300</width>
            <height>840</height>
            <animation effect="zoom" start="90" end="100" center="auto" time="250" tween="quadratic" easing="out">WindowOpen</animation>
            <animation effect="zoom" start="100" end="90" center="auto" time="200" tween="quadratic" easing="in">WindowClose</animation>

            <!-- Box Background (LIGHT GRAY) -->
            <control type="image">
                <width>1300</width>
                <height>840</height>
                <texture border="40">circle.png</texture>
                <colordiffuse>FF555555</colordiffuse> <!-- LIGHTER GRAY -->
            </control>
            
            <control type="image">
                <left>10</left>
                <top>10</top>
                <width>1280</width>
                <height>820</height>
                <texture border="40">circle.png</texture>
                <colordiffuse>FF333333</colordiffuse> <!-- INNER GRAY -->
            </control>

            <!-- Header Content -->
            <control type="group">
                <left>50</left>
                <top>50</top>
                
                <!-- Poster -->
                <control type="image">
                    <width>280</width>
                    <height>420</height>
                    <aspectratio aligny="top">keep</aspectratio>
                    <texture border="2">$INFO[Window.Property(tmdbmovies.poster)]</texture>
                    <bordertexture border="5">white.png</bordertexture>
                </control>

                <!-- Fanart (Clear) -->
                <control type="image">
                    <left>320</left>
                    <width>880</width>
                    <height>420</height>
                    <texture>$INFO[Window.Property(tmdbmovies.fanart)]</texture>
                    <aspectratio align="center">scale</aspectratio>
                </control>
            </control>

            <!-- Metadata Section (Non-scrolling) -->
            <control type="group">
                <left>70</left>
                <top>490</top>
                <width>1160</width>

                <!-- Left Column: Details -->
                <control type="grouplist">
                    <width>750</width>
                    <height>320</height>
                    <itemgap>5</itemgap>
                    <orientation>vertical</orientation>

                    <!-- RELEASE NAME (Scrolling Label to save space) -->
                    <control type="label">
                        <width>750</width>
                        <height>45</height>
                        <font>font14</font>
                        <scroll>true</scroll>
                        <label>[COLOR $INFO[Window.Property(tmdbmovies.highlight)]][B]RELEASE:[/B][/COLOR] $INFO[Window.Property(tmdbmovies.release_name)]</label>
                    </control>

                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[COLOR $INFO[Window.Property(tmdbmovies.highlight)]][B]PROVIDER:[/B][/COLOR] $INFO[Window.Property(tmdbmovies.provider)]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[COLOR $INFO[Window.Property(tmdbmovies.highlight)]][B]INDEXER / SITE:[/B][/COLOR] $INFO[Window.Property(tmdbmovies.indexer)]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[COLOR $INFO[Window.Property(tmdbmovies.highlight)]][B]SERVER / DEBRID:[/B][/COLOR] $INFO[Window.Property(tmdbmovies.server_label)]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[COLOR $INFO[Window.Property(tmdbmovies.highlight)]][B]STREAM STATUS:[/B][/COLOR] $INFO[Window.Property(tmdbmovies.status_clean)]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[COLOR $INFO[Window.Property(tmdbmovies.highlight)]][B]MĂRIME:[/B][/COLOR] [COLOR cyan][B]$INFO[Window.Property(tmdbmovies.size)][/B][/COLOR]</label>
                    </control>
                    <control type="label">
                        <width>750</width>
                        <height>35</height>
                        <font>font14</font>
                        <label>[COLOR $INFO[Window.Property(tmdbmovies.highlight)]][B]CODEC / GROUP:[/B][/COLOR] $INFO[Window.Property(tmdbmovies.codec)] | $INFO[Window.Property(tmdbmovies.group)]</label>
                    </control>
                </control>

                <!-- Right Column: Quality & Tags -->
                <control type="group">
                    <left>800</left>
                    <control type="image">
                        <width>320</width>
                        <height>100</height>
                        <texture border="20">white.png</texture>
                        <colordiffuse>$INFO[Window.Property(tmdbmovies.highlight)]</colordiffuse>
                    </control>
                    <control type="label">
                        <width>320</width>
                        <height>100</height>
                        <font>font45_title</font>
                        <align>center</align>
                        <aligny>center</aligny>
                        <label>$INFO[Window.Property(tmdbmovies.quality)]</label>
                        <textcolor>FF000000</textcolor>
                    </control>

                    <control type="group">
                        <top>140</top>
                        <control type="label">
                            <width>320</width>
                            <height>30</height>
                            <font>font13</font>
                            <align>center</align>
                            <label>[COLOR gray]ATTRIBUTES[/COLOR]</label>
                        </control>
                        <control type="textbox">
                            <top>50</top> 
                            <width>320</width>
                            <height>120</height>
                            <font>font12</font>
                            <align>center</align>
                            <label>$INFO[Window.Property(tmdbmovies.tags)]</label>
                            <textcolor>FFFFFFFF</textcolor>
                        </control>
                    </control>
                </control>
            </control>

            <!-- Back Hint -->
            <control type="label">
                <right>50</right>
                <bottom>25</bottom>
                <width>500</width>
                <align>right</align>
                <font>font11</font>
                <label>BACK to results</label>
                <textcolor>FFBBBBBB</textcolor>
            </control>
        </control>
    </controls>
</window>
