<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <defaultcontrol always="true">3022</defaultcontrol>
    <controls>

        <!-- ─── FUNDAL ─────────────────────────────────────────── -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="FF000000">white.png</texture>
        </control>

        <!-- Fanart 10% opacitate -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <aspectratio>scale</aspectratio>
            <texture background="true">$INFO[Window.Property(tmdbmovies.fanart)]</texture>
            <colordiffuse>90FFFFFF</colordiffuse>
            <animation effect="fade" start="0" end="100" time="700" tween="sine">WindowOpen</animation>
        </control>

        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="40000000">white.png</texture>
        </control>

        <!-- CLEARLOGO (Stânga Sus - Aliniat la stânga) -->
        <control type="image">
            <left>40</left><top>35</top>
            <height>165</height><width>600</width>
            <aspectratio align="left" aligny="center">keep</aspectratio>
            <texture background="true">$INFO[Window.Property(tmdbmovies.clearlogo)]</texture>
            <animation effect="fade" start="0" end="100" time="500" delay="150" tween="sine">WindowOpen</animation>
            <visible>!String.IsEmpty(Window.Property(tmdbmovies.clearlogo))</visible>
        </control>
        
        <control type="label">
            <left>35</left><top>55</top><width>800</width><height>60</height>
            <font>font14</font><textcolor>FFFFFFFF</textcolor><align>left</align>
            <label>[B]$INFO[Window.Property(tmdbmovies.show_title)][/B]</label>
            <visible>String.IsEmpty(Window.Property(tmdbmovies.clearlogo))</visible>
        </control>

        <!-- ─── CARDUL CENTRAL (Formatul identic 800x280px) ──────────── -->
        <control type="group">
            <centerleft>50%</centerleft><top>511</top>
            <width>800</width><height>280</height>
            <animation effect="fade" start="0" end="100" time="400" delay="200" tween="sine">WindowOpen</animation>
            <animation effect="fade" start="100" end="0"  time="200" tween="sine">WindowClose</animation>

            <!-- Fundal cristal 50% -->
            <control type="image">
                <left>0</left><top>0</top>
                <width>796</width><height>274</height>
                <texture border="20">common/white_rounded.png</texture>
                <colordiffuse>85141414</colordiffuse>
            </control>

            <!-- Text mic: "WATCH NEXT EPISODE?" -->
            <control type="label">
                <left>26</left><top>14</top><width>740</width><height>18</height>
                <font>font10</font><textcolor>77FFFFFF</textcolor>
                <label>[B][COLOR FFCCCCFF]EPISODUL URMĂTOR?[/COLOR][/B]</label>
            </control>

            <!-- ShowTitle — S0XE0X -->
            <control type="grouplist">
                <orientation>horizontal</orientation>
                <left>26</left><top>46</top><height>48</height><itemgap>0</itemgap>
                <control type="label">
                    <width>auto</width><height>48</height><aligny>center</aligny>
                    <font>font12</font><textcolor>FF00CED1</textcolor><shadowcolor>ff000000</shadowcolor>
                    <label>[B]$INFO[Window.Property(tmdbmovies.show_title)][/B]</label>
                    <visible>!String.IsEmpty(Window.Property(tmdbmovies.show_title))</visible>
                </control>
                <control type="label">
                    <width>auto</width><height>48</height><aligny>center</aligny>
                    <font>font12</font><textcolor>55FFFFFF</textcolor><shadowcolor>ff000000</shadowcolor>
                    <label> — </label>
                </control>
                <control type="label">
                    <width>auto</width><height>48</height><aligny>center</aligny>
                    <font>font12</font><textcolor>FF00FA9A</textcolor><shadowcolor>ff000000</shadowcolor>
                    <label>[B]$INFO[Window.Property(tmdbmovies.ep_label)][/B]</label>
                    <visible>!String.IsEmpty(Window.Property(tmdbmovies.ep_label))</visible>
                </control>
            </control>

            <!-- Linie Divider -->
            <control type="image">
                <left>16</left><top>100</top><width>764</width><height>1</height>
                <texture>white.png</texture><colordiffuse>2AFFFFFF</colordiffuse>
            </control>

            <!-- Countdown Timer -->
            <control type="label">
                <right>24</right><top>109</top><width>350</width><height>20</height>
                <font>font10</font><align>right</align><textcolor>55FFFFFF</textcolor>
                <label>Se închide în [COLOR FFFF4444][B]$INFO[Window.Property(tmdbmovies.next_ep_countdown)][/B][/COLOR]s</label>
            </control>

            <!-- ── BUTOANE ────────────────── -->
            <control type="grouplist" id="3000">
                <orientation>horizontal</orientation>
                <left>18</left><top>167</top>
                <height>68</height><itemgap>8</itemgap>
                <usecontrolcoords>true</usecontrolcoords>

                <!-- Auto-Play -->
                <control type="button" id="3021">
                    <width>240</width><height>68</height>
                    <label>[COLOR FF6AFB92][B]Auto-Play[/B][/COLOR]</label>
                    <font>font20_title</font><aligny>center</aligny><align>center</align>
                    <pulseonselect>no</pulseonselect><shadowcolor>ff000000</shadowcolor>
                    <texturefocus border="10" colordiffuse="40D0D0D0">common/button1.png</texturefocus>
                    <texturenofocus border="10" colordiffuse="FF1E1E1E">common/button1.png</texturenofocus>
                </control>

                <!-- Nu Acum -->
                <control type="button" id="3022">
                    <width>240</width><height>68</height>
                    <label>[COLOR FFFF4444][B]Nu Acum[/B][/COLOR]</label>
                    <font>font20_title</font><aligny>center</aligny><align>center</align>
                    <pulseonselect>no</pulseonselect><shadowcolor>ff000000</shadowcolor>
                    <texturefocus border="10" colordiffuse="40D0D0D0">common/button1.png</texturefocus>
                    <texturenofocus border="10" colordiffuse="FF1E1E1E">common/button1.png</texturenofocus>
                </control>

                <!-- Alege Sursa -->
                <control type="button" id="3023">
                    <width>270</width><height>68</height>
                    <label>[COLOR FFE8A030][B]Alege Sursa[/B][/COLOR]</label>
                    <font>font20_title</font><aligny>center</aligny><align>center</align>
                    <pulseonselect>no</pulseonselect><shadowcolor>ff000000</shadowcolor>
                    <texturefocus border="10" colordiffuse="40D0D0D0">common/button1.png</texturefocus>
                    <texturenofocus border="10" colordiffuse="FF1E1E1E">common/button1.png</texturenofocus>
                </control>
            </control>

        </control>

    </controls>
</window>