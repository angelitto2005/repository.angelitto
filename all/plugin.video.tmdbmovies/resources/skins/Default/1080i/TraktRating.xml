<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <defaultcontrol always="true">11039</defaultcontrol>
    <controls>

        <!-- ─── FUNDAL COMPLET ÎNTUNECAT ─────────────────────────────────── -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="FF000000">white.png</texture>
        </control>

        <!-- Fanart difuz cu 10% (90FFFFFF) opacitate - Exact ca la AutoPlay -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <aspectratio>scale</aspectratio>
            <texture background="true">$INFO[Window.Property(tmdbmovies.fanart)]</texture>
            <colordiffuse>90FFFFFF</colordiffuse>
            <animation effect="fade" start="0" end="100" time="700" tween="sine">WindowOpen</animation>
        </control>

        <!-- Un filtru negru suplimentar pentru lizibilitate -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="40000000">white.png</texture>
        </control>

        <!-- ─── CLEARLOGO (Exact ca la AutoPlay) ───────────────────────── -->
        <control type="image">
            <left>40</left><top>35</top>
            <height>165</height><width>600</width>
            <aspectratio align="left" aligny="center">keep</aspectratio>
            <texture background="true">$INFO[Window.Property(tmdbmovies.clearlogo)]</texture>
            <animation effect="fade" start="0" end="100" time="500" delay="150" tween="sine">WindowOpen</animation>
            <visible>!String.IsEmpty(Window.Property(tmdbmovies.clearlogo))</visible>
        </control>
        
        <!-- Text de fallback dacă nu există ClearLogo -->
        <control type="label">
            <left>35</left><top>55</top><width>800</width><height>60</height>
            <font>font14</font><textcolor>FFFFFFFF</textcolor><align>left</align>
            <label>[B]$INFO[Window.Property(tmdbmovies.show_title)][/B]</label>
            <visible>String.IsEmpty(Window.Property(tmdbmovies.clearlogo))</visible>
        </control>

        <!-- ─── CARDUL CENTRAL ─────────────────────────────────────────── -->
        <control type="group">
            <centerleft>50%</centerleft><centertop>50%</centertop>
            <width>800</width><height>280</height>
            <animation effect="zoom" start="80" end="100" center="auto" time="250" tween="back" easing="out">WindowOpen</animation>
            <animation effect="fade" start="0" end="100" time="250">WindowOpen</animation>
            <animation effect="zoom" start="100" end="80" center="auto" time="200" tween="back" easing="in">WindowClose</animation>
            <animation effect="fade" start="100" end="0"  time="200">WindowClose</animation>

            <!-- Fundal cristal -->
            <control type="image">
                <left>0</left><top>0</top>
                <width>800</width><height>280</height>
                <texture border="20">common/white_rounded.png</texture>
                <colordiffuse>992E2E2E</colordiffuse>
            </control>

            <!-- Buton Închidere invizibil pentru mouse -->
            <control type="button" id="1000">
                <posx>-2000</posx><posy>-2000</posy><width>1</width><height>1</height>
                <label></label><texturefocus></texturefocus><texturenofocus></texturenofocus>
                <visible>system.getbool(input.enablemouse)</visible>
            </control>

            <!-- Text mic sus + Iconiță -->
            <control type="group">
                <left>26</left><top>14</top>
                <control type="label">
                    <left>0</left><top>0</top><width>600</width><height>18</height>
                    <font>font10</font><textcolor>77FFFFFF</textcolor>
                    <label>[B][COLOR FFCCCCFF]$INFO[Window.Property(tmdbmovies.service_title)][/COLOR][/B]</label>
                </control>
                <control type="image">
                    <left>680</left><top>-10</top><width>96</width><height>96</height>
                    <texture>$INFO[Window.Property(tmdbmovies.service_icon)]</texture>
                    <aspectratio>keep</aspectratio>
                </control>
            </control>

            <!-- Titlu (Show + Episod sau Film) -->
            <control type="grouplist">
                <orientation>horizontal</orientation>
                <left>26</left><top>46</top><height>48</height><itemgap>0</itemgap>
                <control type="label">
                    <width>auto</width><height>48</height><aligny>center</aligny>
                    <font>font12</font><textcolor>FF00CED1</textcolor><shadowcolor>ff000000</shadowcolor>
                    <label>[B]$INFO[Window.Property(tmdbmovies.show_title)][/B]</label>
                    <visible>!String.IsEmpty(Window.Property(tmdbmovies.show_title))</visible>
                </control>
                <control type="label">
                    <width>auto</width><height>48</height><aligny>center</aligny>
                    <font>font12</font><textcolor>55FFFFFF</textcolor><shadowcolor>ff000000</shadowcolor>
                    <label> — </label>
                    <visible>!String.IsEmpty(Window.Property(tmdbmovies.ep_label))</visible>
                </control>
                <control type="label">
                    <width>auto</width><height>48</height><aligny>center</aligny>
                    <font>font12</font><textcolor>FF00FA9A</textcolor><shadowcolor>ff000000</shadowcolor>
                    <label>[B]$INFO[Window.Property(tmdbmovies.ep_label)][/B]</label>
                    <visible>!String.IsEmpty(Window.Property(tmdbmovies.ep_label))</visible>
                </control>
            </control>

            <!-- Linie Divider -->
