<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <section id="service.torrserver">

        <!--CATEGORY: Update-->
        <category id="update" label="32006">
            <group id="1">
                <setting id="torrserver_version" type="string" label="32090">
                    <level>0</level>
                    <default>-</default>
                    <control type="edit" format="string">
                    </control>
                </setting>
            </group>
        </category>

        <!--CATEGORY: Server-->
        <category id="server" label="32000">
            <group id="2">
                <setting id="torrserver_port" type="integer" label="32010" help="32110">
                    <level>0</level>
                    <default>8090</default>
                    <control type="edit" format="integer">
                        <heading>32010</heading>
                    </control>
                </setting>
                <setting id="download_path" type="string" label="32011" help="32111">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string">
                        <heading>32011</heading>
                    </control>
                </setting>
                <setting id="torrent_disconnect_timeout" type="integer" label="32012" help="32112">
                    <level>0</level>
                    <default>30</default>
                    <control type="edit" format="integer">
                        <heading>32012</heading>
                    </control>
                </setting>
                <setting id="responsive_mode" type="boolean" label="32013" help="32113">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="remove_cache_on_drop" type="boolean" label="32014" help="32114">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="enable_debug" type="boolean" label="32015" help="32115">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
            </group>
        </category>

        <!--CATEGORY: Cache-->
        <category id="cache" label="32001">
            <group id="3">
                <setting id="cache_size" type="integer" label="32020" help="32120">
                    <level>0</level>
                    <default>64</default>
                    <control type="edit" format="integer">
                        <heading>32020</heading>
                    </control>
                </setting>
                <setting id="use_ram" type="boolean" label="32021" help="32121">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="reader_read_ahead" type="integer" label="32022" help="32122">
                    <level>0</level>
                    <default>95</default>
                    <control type="edit" format="integer">
                        <heading>32022</heading>
                    </control>
                </setting>
                <setting id="preload_cache" type="integer" label="32023" help="32123">
                    <level>0</level>
                    <default>50</default>
                    <control type="edit" format="integer">
                        <heading>32023</heading>
                    </control>
                </setting>
            </group>
        </category>

        <!--CATEGORY: BitTorrent-->
        <category id="bittorrent" label="32002">
            <group id="4">
                <setting id="retrackers_mode" type="integer" label="32030" help="32130">
                    <level>0</level>
                    <default>1</default>
                    <constraints>
                        <options>
                            <option label="32070">0</option>
                            <option label="32071">1</option>
                            <option label="32072">2</option>
                            <option label="32073">3</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
                <setting id="force_encrypt" type="boolean" label="32031" help="32131">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="enable_dht" type="boolean" label="32032" help="32132">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="enable_upnp" type="boolean" label="32033" help="32133">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="disable_pex" type="boolean" label="32034" help="32134">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="disable_tcp" type="boolean" label="32035" help="32135">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="disable_utp" type="boolean" label="32036" help="32136">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="disable_upload" type="boolean" label="32037" help="32137">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="enable_ipv6" type="boolean" label="32038" help="32138">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
            </group>
        </category>

        <!--CATEGORY: Transfer Limits-->
        <category id="limits" label="32003">
            <group id="5">
                <setting id="connections_limit" type="integer" label="32040" help="32140">
                    <level>0</level>
                    <default>25</default>
                    <control type="edit" format="integer">
                        <heading>32040</heading>
                    </control>
                </setting>
                <setting id="peers_listen_port" type="integer" label="32041" help="32141">
                    <level>0</level>
                    <default>0</default>
                    <control type="edit" format="integer">
                        <heading>32041</heading>
                    </control>
                </setting>
                <setting id="download_rate" type="integer" label="32042" help="32142">
                    <level>0</level>
                    <default>0</default>
                    <control type="edit" format="integer">
                        <heading>32042</heading>
                    </control>
                </setting>
                <setting id="upload_rate" type="integer" label="32043" help="32143">
                    <level>0</level>
                    <default>0</default>
                    <control type="edit" format="integer">
                        <heading>32043</heading>
                    </control>
                </setting>
            </group>
        </category>

        <!--CATEGORY: DLNA-->
        <category id="dlna" label="32004">
            <group id="6">
                <setting id="enable_dlna" type="boolean" label="32050" help="32150">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="friendly_name" type="string" label="32051" help="32151">
                    <level>0</level>
                    <default>TorrServer</default>
                    <control type="edit" format="string">
                        <heading>32051</heading>
                    </control>
                    <dependencies>
                        <dependency type="enable" setting="enable_dlna">true</dependency>
                    </dependencies>
                </setting>
            </group>
        </category>

        <!--CATEGORY: Authentication-->
        <category id="auth" label="32005">
            <group id="7">
                <setting id="enable_auth" type="boolean" label="32060" help="32160">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="username" type="string" label="32061" help="32161">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string">
                        <heading>32061</heading>
                    </control>
                    <dependencies>
                        <dependency type="enable" setting="enable_auth">true</dependency>
                    </dependencies>
                </setting>
                <setting id="password" type="string" label="32062" help="32162">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string">
                        <hidden>true</hidden>
                        <heading>32062</heading>
                    </control>
                    <dependencies>
                        <dependency type="enable" setting="enable_auth">true</dependency>
                    </dependencies>
                </setting>
            </group>
        </category>

    </section>
</settings>
