# Kodi Media Center language file
# Addon Name: TorrServer Service
# Addon id: service.torrserver
# Addon Provider: yourname
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Language: ro_RO\n"

msgctxt "#32090"
msgid "TorrServer version"
msgstr "Versiune TorrServer"

msgctxt "#32091"
msgid "Not running"
msgstr "Nu ruleaza"

msgctxt "#32092"
msgid "Downloading TorrServer binary, please wait..."
msgstr "Se descarca TorrServer, asteptati..."

msgctxt "#32093"
msgid "TorrServer is starting..."
msgstr "TorrServer porneste..."

msgctxt "#32006"
msgid "Update"
msgstr "Actualizare"

msgctxt "#32080"
msgid "Check for TorrServer update"
msgstr "Verifica actualizare TorrServer"

msgctxt "#32180"
msgid "Checks GitHub for a newer TorrServer binary. If found, asks for confirmation before downloading and restarting."
msgstr "Verifica pe GitHub daca exista un binar mai nou. Daca gaseste, cere confirmare inainte de descarcare si repornire."

msgctxt "#32000"
msgid "Server"
msgstr "Server"

msgctxt "#32001"
msgid "Cache"
msgstr "Cache"

msgctxt "#32002"
msgid "BitTorrent"
msgstr "BitTorrent"

msgctxt "#32003"
msgid "Transfer Limits"
msgstr "Limite Transfer"

msgctxt "#32004"
msgid "DLNA"
msgstr "DLNA"

msgctxt "#32005"
msgid "Authentication"
msgstr "Autentificare"

msgctxt "#32010"
msgid "Port"
msgstr "Port"

msgctxt "#32011"
msgid "Save path for torrents"
msgstr "Cale salvare torente"

msgctxt "#32012"
msgid "Disconnect timeout (sec)"
msgstr "Timeout deconectare (sec)"

msgctxt "#32013"
msgid "Responsive mode"
msgstr "Mod responsiv"

msgctxt "#32014"
msgid "Clear cache on torrent drop"
msgstr "Sterge cache la oprire torrent"

msgctxt "#32015"
msgid "Enable debug logs"
msgstr "Activeaza debug logs"

msgctxt "#32110"
msgid "Port TorrServer listens on. Default 8090. Change only if another service uses the same port."
msgstr "Portul pe care ruleaza TorrServer. Default 8090. Schimba doar daca alt serviciu foloseste acelasi port."

msgctxt "#32111"
msgid "Folder where torrent files are saved. Leave empty for TorrServer default folder."
msgstr "Folderul unde se salveaza fisierele torrent. Lasa gol pentru folderul implicit al TorrServer."

msgctxt "#32112"
msgid "How long to wait before disconnecting an inactive torrent. Recommended: 30-60 sec."
msgstr "Cat timp asteapta inainte sa deconecteze un torrent inactiv. Recomandat: 30-60 sec."

msgctxt "#32113"
msgid "Optimizes read-ahead for live streaming. Recommended ON for movies/series. OFF for pure download only."
msgstr "Optimizeaza read-ahead pentru streaming live. Recomandat ON pentru filme/seriale. OFF doar pentru download pur."

msgctxt "#32114"
msgid "Clears memory cache when torrent is stopped. ON saves RAM but next playback will buffer again."
msgstr "Sterge cache-ul din memorie cand torrentul este oprit. ON economiseste RAM dar urmatoarea redare va buffera din nou."

msgctxt "#32115"
msgid "Writes detailed info to log. Use only for troubleshooting - slows server on weak devices."
msgstr "Scrie informatii detaliate in log. Foloseste doar pentru depanare - incetineste serverul pe dispozitive slabe."

msgctxt "#32020"
msgid "Cache size (MB)"
msgstr "Dimensiune cache (MB)"

msgctxt "#32021"
msgid "Cache in RAM"
msgstr "Cache in RAM"

msgctxt "#32022"
msgid "Read-ahead buffer (%)"
msgstr "Buffer read-ahead (%)"

msgctxt "#32023"
msgid "Initial preload (%)"
msgstr "Preincarcare initiala (%)"

msgctxt "#32120"
msgid "Recommended: 64MB for RPi3/low RAM devices, 256MB for RPi4, 512MB+ for PC/NUC. Higher values reduce re-buffering."
msgstr "Recomandat: 64MB pentru RPi3/cutii cu RAM putin, 256MB pentru RPi4, 512MB+ pentru PC/NUC. Valori mari reduc re-buffering-ul."

msgctxt "#32121"
msgid "ON = fast RAM cache (recommended). OFF = disk cache, slower but saves RAM. Useful on devices with under 1GB free RAM."
msgstr "ON = cache rapid in RAM (recomandat). OFF = cache pe disc, mai lent dar nu consuma RAM. Util pe dispozitive cu sub 1GB RAM liber."

msgctxt "#32122"
msgid "Percentage of cache preloaded ahead. 95% recommended for stable streaming. Lower to 50-70% if torrent starts slowly."
msgstr "Cat % din cache se preincarca inainte. 95% recomandat pentru streaming stabil. Scade la 50-70% daca torrentul porneste greu."

msgctxt "#32123"
msgid "Percentage of cache filled before playback starts. 50% balances wait time and stability. Increase on slow connections."
msgstr "Cat % din cache trebuie umplut inainte de a incepe redarea. 50% = echilibru intre timp de asteptare si stabilitate. Creste pe conexiuni lente."

msgctxt "#32030"
msgid "Retrackers mode"
msgstr "Mod retrackers"

msgctxt "#32031"
msgid "Force encryption"
msgstr "Forteaza criptare"

msgctxt "#32032"
msgid "Enable DHT"
msgstr "Activeaza DHT"

msgctxt "#32033"
msgid "Enable UPnP"
msgstr "Activeaza UPnP"

msgctxt "#32034"
msgid "Disable PEX"
msgstr "Dezactiveaza PEX"

msgctxt "#32035"
msgid "Disable TCP"
msgstr "Dezactiveaza TCP"

msgctxt "#32036"
msgid "Disable UTP"
msgstr "Dezactiveaza UTP"

msgctxt "#32037"
msgid "Disable upload"
msgstr "Dezactiveaza upload"

msgctxt "#32038"
msgid "Enable IPv6"
msgstr "Activeaza IPv6"

msgctxt "#32070"
msgid "Do not add"
msgstr "Nu adauga"

msgctxt "#32071"
msgid "Add retrackers"
msgstr "Adauga retrackers"

msgctxt "#32072"
msgid "Remove retrackers"
msgstr "Elimina retrackers"

msgctxt "#32073"
msgid "Replace retrackers"
msgstr "Inlocuieste retrackers"

msgctxt "#32130"
msgid "Retrackers are additional trackers. Mode 1 (Add) increases speed on some torrents. Mode 0 recommended for international torrents."
msgstr "Retrackerele sunt trackere suplimentare. Mod 1 (Adauga) creste viteza pe unele torrente. Mod 0 recomandat pentru torrente internationale."

msgctxt "#32131"
msgid "Encrypts all BitTorrent traffic. Useful if ISP throttles torrents. May reduce speed and available peers."
msgstr "Cripteaza tot traficul BitTorrent. Util daca ISP-ul throttleaza torrentele. Poate reduce viteza si numarul de peers disponibili."

msgctxt "#32132"
msgid "DHT allows finding peers without a tracker. Recommended ON. Disable only if network blocks DHT or for private torrents."
msgstr "DHT permite gasirea de peers fara tracker. Recomandat ON. Dezactiveaza doar daca reteaua blocheaza DHT sau pentru torrente private."

msgctxt "#32133"
msgid "Automatically opens port in router via UPnP. Recommended ON. OFF if you set up manual port forwarding or router lacks UPnP."
msgstr "Deschide automat portul in router prin UPnP. Recomandat ON. OFF daca ai facut port forwarding manual sau router-ul nu suporta UPnP."

msgctxt "#32134"
msgid "PEX = peer exchange between clients. Recommended OFF (PEX active). Enable disable only for private torrents where PEX is forbidden."
msgstr "PEX = schimb de peers intre clienti. Recomandat OFF (PEX activ). Activeaza dezactivarea doar pentru torrente private unde PEX e interzis."

msgctxt "#32135"
msgid "Disables TCP BitTorrent connections. Recommended OFF. Enable only if ISP blocks TCP on torrent ports."
msgstr "Dezactiveaza conexiunile TCP BitTorrent. Recomandat OFF. Activeaza doar daca ISP-ul blocheaza TCP pe porturi torrent."

msgctxt "#32136"
msgid "UTP = adaptive protocol reducing network latency. Recommended OFF (UTP active). Disable if you have speed issues on congested networks."
msgstr "UTP = protocol adaptiv care reduce latenta retelei. Recomandat OFF (UTP activ). Dezactiveaza daca ai probleme de viteza pe retele congestionate."

msgctxt "#32137"
msgid "Completely stops uploading to other peers. Useful on limited mobile data. Negatively affects ratio on private trackers."
msgstr "Opreste complet upload-ul catre alti peers. Util daca ai date mobile limitate. Afecteaza negativ ratio-ul pe trackere private."

msgctxt "#32138"
msgid "Enables IPv6 connections. Enable only if your ISP provides IPv6 and you want access to more peers."
msgstr "Activeaza conexiuni IPv6. Porneste doar daca ISP-ul tau ofera IPv6 si vrei sa beneficiezi de mai multi peers."

msgctxt "#32040"
msgid "Connections limit"
msgstr "Limita conexiuni"

msgctxt "#32041"
msgid "Peers listen port (0=auto)"
msgstr "Port peers (0=auto)"

msgctxt "#32042"
msgid "Download limit KB/s (0=unlimited)"
msgstr "Limita download KB/s (0=nelimitat)"

msgctxt "#32043"
msgid "Upload limit KB/s (0=unlimited)"
msgstr "Limita upload KB/s (0=nelimitat)"

msgctxt "#32140"
msgid "Maximum simultaneous peers. Recommended: 25 for RPi3/4, 50-100 for PC. Higher values increase speed but also CPU/RAM usage."
msgstr "Numarul maxim de peers simultani. Recomandat: 25 pentru RPi3/4, 50-100 pentru PC. Valori mari cresc viteza dar si consumul de CPU/RAM."

msgctxt "#32141"
msgid "Port TorrServer listens on for peer connections. 0 = auto. Set manually if you have specific port forwarding in your router."
msgstr "Portul pe care TorrServer asculta conexiuni de la peers. 0 = ales automat. Seteaza manual daca ai facut port forwarding specific in router."

msgctxt "#32142"
msgid "Limits download speed. 0 = unlimited (recommended). Set e.g. 5000 for ~5MB/s to preserve bandwidth for other uses."
msgstr "Limiteaza viteza de download. 0 = nelimitat (recomandat). Seteaza ex. 5000 pentru ~5MB/s daca vrei sa pastrezi banda pentru altceva."

msgctxt "#32143"
msgid "Limits upload speed. 0 = unlimited. Recommended to limit on asymmetric connections (e.g. 500 = 500KB/s) to avoid blocking downloads."
msgstr "Limiteaza viteza de upload. 0 = nelimitat. Recomandat sa limitezi pe conexiuni asimetrice (ex. 500 = 500KB/s) pentru a nu bloca download-ul."

msgctxt "#32050"
msgid "Enable DLNA"
msgstr "Activeaza DLNA"

msgctxt "#32051"
msgid "DLNA friendly name"
msgstr "Nume DLNA"

msgctxt "#32150"
msgid "Exposes TorrServer as a DLNA media server on the network. Useful for Smart TVs or players without Kodi addon. Uses few extra resources."
msgstr "Expune TorrServer ca server media DLNA in retea. Util pentru Smart TV-uri sau playere fara addon Kodi. Consuma putine resurse suplimentare."

msgctxt "#32151"
msgid "Name TorrServer appears as in the DLNA device list. Change if you have multiple TorrServer instances on the network."
msgstr "Numele sub care apare TorrServer in lista de dispozitive DLNA. Schimba daca ai mai multe instante TorrServer in retea."

msgctxt "#32060"
msgid "Enable HTTP authentication"
msgstr "Activeaza autentificare HTTP"

msgctxt "#32061"
msgid "Username"
msgstr "Utilizator"

msgctxt "#32062"
msgid "Password"
msgstr "Parola"

msgctxt "#32160"
msgid "Protects TorrServer with username and password. Recommended ON if TorrServer is accessible from outside the local network."
msgstr "Protejeaza TorrServer cu user si parola. Recomandat ON daca TorrServer e accesibil din afara retelei locale."

msgctxt "#32161"
msgid "Username for HTTP Basic authentication. Minimum 4 characters recommended."
msgstr "Numele de utilizator pentru autentificarea HTTP Basic. Minim 4 caractere recomandat."

msgctxt "#32162"
msgid "Password for HTTP Basic authentication. Use a strong password if TorrServer is exposed to the internet."
msgstr "Parola pentru autentificarea HTTP Basic. Foloseste o parola puternica daca TorrServer e expus pe internet."
