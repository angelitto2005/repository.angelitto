# Kodi Media Center language file
# Addon Name: TorrServer Service
# Addon id: service.torrserver
# Addon Provider: yourname
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Language: ro_RO\n"

msgctxt "#32092"
msgid "Downloading TorrServer binary, please wait..."
msgstr "Se descarcă binarul TorrServer, vă rugăm așteptați..."

msgctxt "#32093"
msgid "TorrServer is starting..."
msgstr "TorrServer pornește..."

msgctxt "#32006"
msgid "Update"
msgstr "Actualizare"

msgctxt "#32080"
msgid "Auto-update binary"
msgstr "Actualizare automată binar"

msgctxt "#32083"
msgid "Automatically check and update TorrServer binary at startup if a new version is available on GitHub."
msgstr "Verifică și actualizează automat binarul TorrServer la pornire dacă există o versiune nouă pe GitHub."

msgctxt "#32081"
msgid "Select version"
msgstr "Selectează versiunea"

msgctxt "#32084"
msgid "Browse and install any of the last 10 released versions of TorrServer for your platform."
msgstr "Răsfoiește și instalează oricare dintre ultimele 10 versiuni lansate de TorrServer pentru platforma ta."

msgctxt "#32082"
msgid "Rollback"
msgstr "Restaurare versiune anterioară"

msgctxt "#32086"
msgid "Show version on start"
msgstr "Afișează versiunea la pornire"

msgctxt "#32087"
msgid "Display a notification with the running TorrServer version at Kodi startup."
msgstr "Afișează o notificare cu versiunea TorrServer care rulează la pornirea Kodi."

msgctxt "#32088"
msgid "Notify if update available"
msgstr "Anunță dacă există actualizare"

msgctxt "#32089"
msgid "Show a notification at startup if a newer TorrServer version is available on GitHub. Does not install automatically."
msgstr "Afișează o notificare la pornire dacă există o versiune mai nouă pe GitHub. Nu instalează automat."

msgctxt "#32085"
msgid "Restore the previous binary version. Available only if a backup exists from the last update."
msgstr "Restaurează versiunea anterioară a binarului. Disponibil doar dacă există un backup de la ultima actualizare."

msgctxt "#32000"
msgid "Server"
msgstr "Server"

msgctxt "#32010"
msgid "Port"
msgstr "Port"

msgctxt "#32110"
msgid "Port TorrServer listens on. Default 8090. Change only if another service uses the same port."
msgstr "Portul pe care TorrServer ascultă. Implicit 8090. Modificați numai dacă un alt serviciu folosește același port."

msgctxt "#32011"
msgid "Save path for torrents"
msgstr "Cale de salvare pentru torrente"

msgctxt "#32111"
msgid "Folder where torrent files are saved. Leave empty for TorrServer default folder."
msgstr "Folderul în care sunt salvate fișierele torrent. Lăsați gol pentru folderul implicit TorrServer."

msgctxt "#32012"
msgid "Disconnect timeout (sec)"
msgstr "Timeout deconectare (sec)"

msgctxt "#32112"
msgid "How long to wait before disconnecting an inactive torrent. Recommended: 30-60 sec."
msgstr "Cât timp să aștepte înainte de a deconecta un torrent inactiv. Recomandat: 30-60 sec."

msgctxt "#32013"
msgid "Responsive mode"
msgstr "Mod responsiv"

msgctxt "#32113"
msgid "Optimizes read-ahead for live streaming. Recommended ON for movies/series. OFF for pure download only."
msgstr "Optimizează citirea în avans pentru streaming live. Recomandat ON pentru filme/seriale. OFF doar pentru descărcare pură."

msgctxt "#32014"
msgid "Clear cache on torrent drop"
msgstr "Șterge cache la oprirea torrentului"

msgctxt "#32114"
msgid "Clears memory cache when torrent is stopped. ON saves RAM but next playback will buffer again."
msgstr "Șterge memoria cache când torrentul este oprit. ON economisește RAM, dar redarea următoare va face buffering din nou."

msgctxt "#32015"
msgid "Enable debug logs"
msgstr "Activează jurnale de depanare"

msgctxt "#32115"
msgid "Writes detailed info to log. Use only for troubleshooting - slows server on weak devices."
msgstr "Scrie informații detaliate în jurnal. Folosiți numai pentru depanare - încetinește serverul pe dispozitive slabe."

msgctxt "#32001"
msgid "Cache"
msgstr "Cache"

msgctxt "#32020"
msgid "Cache size (MB)"
msgstr "Dimensiune cache (MB)"

msgctxt "#32120"
msgid "Recommended: 64MB for RPi3/low RAM devices, 256MB for RPi4, 512MB+ for PC/NUC. Higher values reduce re-buffering."
msgstr "Recomandat: 64MB pentru RPi3/dispozitive cu RAM mică, 256MB pentru RPi4, 512MB+ pentru PC/NUC. Valorile mai mari reduc re-bufferingul."

msgctxt "#32021"
msgid "Cache in RAM"
msgstr "Cache în RAM"

msgctxt "#32121"
msgid "ON = fast RAM cache (recommended). OFF = disk cache, slower but saves RAM. Useful on devices with under 1GB free RAM."
msgstr "ON = cache rapid în RAM (recomandat). OFF = cache pe disc, mai lent dar economisește RAM. Util pe dispozitive cu mai puțin de 1GB RAM liber."

msgctxt "#32022"
msgid "Read-ahead buffer (%)"
msgstr "Buffer de citire în avans (%)"

msgctxt "#32122"
msgid "Percentage of cache preloaded ahead. 95% recommended for stable streaming. Lower to 50-70% if torrent starts slowly."
msgstr "Procent din cache preîncărcat în avans. 95% recomandat pentru streaming stabil. Scădeți la 50-70% dacă torrentul pornește lent."

msgctxt "#32023"
msgid "Initial preload (%)"
msgstr "Preîncărcare inițială (%)"

msgctxt "#32123"
msgid "Percentage of cache filled before playback starts. 50% balances wait time and stability. Increase on slow connections."
msgstr "Procent din cache completat înainte ca redarea să înceapă. 50% echilibrează timpul de așteptare și stabilitatea. Creșteți pe conexiuni lente."

msgctxt "#32002"
msgid "BitTorrent"
msgstr "BitTorrent"

msgctxt "#32030"
msgid "Retrackers mode"
msgstr "Mod retrackers"

msgctxt "#32070"
msgid "Do not add"
msgstr "Nu adăuga"

msgctxt "#32071"
msgid "Add retrackers"
msgstr "Adaugă retrackers"

msgctxt "#32072"
msgid "Remove retrackers"
msgstr "Elimină retrackers"

msgctxt "#32073"
msgid "Replace retrackers"
msgstr "Înlocuiește retrackers"

msgctxt "#32130"
msgid "Retrackers are additional trackers. Mode 1 (Add) increases speed on some torrents. Mode 0 recommended for international torrents."
msgstr "Retrackers sunt trackere suplimentare. Modul 1 (Adaugă) crește viteza pe unele torrente. Modul 0 recomandat pentru torrente internaționale."

msgctxt "#32031"
msgid "Force encryption"
msgstr "Forțează criptarea"

msgctxt "#32131"
msgid "Encrypts all BitTorrent traffic. Useful if ISP throttles torrents. May reduce speed and available peers."
msgstr "Criptează tot traficul BitTorrent. Util dacă ISP-ul limitează torrentele. Poate reduce viteza și numărul de peeri disponibili."

msgctxt "#32032"
msgid "Enable DHT"
msgstr "Activează DHT"

msgctxt "#32132"
msgid "DHT allows finding peers without a tracker. Recommended ON. Disable only if network blocks DHT or for private torrents."
msgstr "DHT permite găsirea de peeri fără tracker. Recomandat ON. Dezactivați numai dacă rețeaua blochează DHT sau pentru torrente private."

msgctxt "#32033"
msgid "Enable UPnP"
msgstr "Activează UPnP"

msgctxt "#32133"
msgid "Automatically opens port in router via UPnP. Recommended ON. OFF if you set up manual port forwarding or router lacks UPnP."
msgstr "Deschide automat portul în router prin UPnP. Recomandat ON. OFF dacă ați configurat redirecționare manuală a portului sau routerul nu are UPnP."

msgctxt "#32034"
msgid "Disable PEX"
msgstr "Dezactivează PEX"

msgctxt "#32134"
msgid "PEX = peer exchange between clients. Recommended OFF (PEX active). Enable only for private torrents where PEX is forbidden."
msgstr "PEX = schimb de peeri între clienți. Recomandat OFF (PEX activ). Activați numai pentru torrente private unde PEX este interzis."

msgctxt "#32035"
msgid "Disable TCP"
msgstr "Dezactivează TCP"

msgctxt "#32135"
msgid "Disables TCP BitTorrent connections. Recommended OFF. Enable only if ISP blocks TCP on torrent ports."
msgstr "Dezactivează conexiunile TCP BitTorrent. Recomandat OFF. Activați numai dacă ISP-ul blochează TCP pe porturile de torrente."

msgctxt "#32036"
msgid "Disable UTP"
msgstr "Dezactivează UTP"

msgctxt "#32136"
msgid "UTP = adaptive protocol reducing network latency. Recommended OFF (UTP active). Disable if you have speed issues on congested networks."
msgstr "UTP = protocol adaptiv care reduce latența rețelei. Recomandat OFF (UTP activ). Dezactivați dacă aveți probleme de viteză pe rețele aglomerate."

msgctxt "#32037"
msgid "Disable upload"
msgstr "Dezactivează încărcarea"

msgctxt "#32137"
msgid "Completely stops uploading to other peers. Useful on limited mobile data. Negatively affects ratio on private trackers."
msgstr "Oprește complet încărcarea către alți peeri. Util pe date mobile limitate. Afectează negativ raportul pe trackere private."

msgctxt "#32038"
msgid "Enable IPv6"
msgstr "Activează IPv6"

msgctxt "#32138"
msgid "Enables IPv6 connections. Enable only if your ISP provides IPv6 and you want access to more peers."
msgstr "Activează conexiunile IPv6. Activați numai dacă ISP-ul oferă IPv6 și doriți acces la mai mulți peeri."

msgctxt "#32003"
msgid "Transfer Limits"
msgstr "Limite de transfer"

msgctxt "#32040"
msgid "Connections limit"
msgstr "Limită conexiuni"

msgctxt "#32140"
msgid "Maximum simultaneous peers. Recommended: 25 for RPi3/4, 50-100 for PC. Higher values increase speed but also CPU/RAM usage."
msgstr "Numărul maxim de peeri simultani. Recomandat: 25 pentru RPi3/4, 50-100 pentru PC. Valorile mai mari cresc viteza, dar și utilizarea CPU/RAM."

msgctxt "#32041"
msgid "Peers listen port (0=auto)"
msgstr "Port pentru peeri (0=auto)"

msgctxt "#32141"
msgid "Port TorrServer listens on for peer connections. 0 = auto. Set manually if you have specific port forwarding in your router."
msgstr "Portul pe care TorrServer ascultă pentru conexiunile peer. 0 = auto. Setați manual dacă aveți redirecționare specifică a portului în router."

msgctxt "#32042"
msgid "Download limit KB/s (0=unlimited)"
msgstr "Limită descărcare KB/s (0=nelimitat)"

msgctxt "#32142"
msgid "Limits download speed. 0 = unlimited (recommended). Set e.g. 5000 for ~5MB/s to preserve bandwidth for other uses."
msgstr "Limitează viteza de descărcare. 0 = nelimitat (recomandat). Setați de exemplu 5000 pentru ~5MB/s pentru a păstra lățime de bandă pentru alte utilizări."

msgctxt "#32043"
msgid "Upload limit KB/s (0=unlimited)"
msgstr "Limită încărcare KB/s (0=nelimitat)"

msgctxt "#32143"
msgid "Limits upload speed. 0 = unlimited. Recommended to limit on asymmetric connections (e.g. 500 = 500KB/s) to avoid blocking downloads."
msgstr "Limitează viteza de încărcare. 0 = nelimitat. Recomandat să limitați pe conexiuni asimetrice (de ex. 500 = 500KB/s) pentru a evita blocarea descărcărilor."

msgctxt "#32004"
msgid "DLNA"
msgstr "DLNA"

msgctxt "#32050"
msgid "Enable DLNA"
msgstr "Activează DLNA"

msgctxt "#32150"
msgid "Exposes TorrServer as a DLNA media server on the network. Useful for Smart TVs or players without Kodi addon. Uses few extra resources."
msgstr "Expune TorrServer ca server media DLNA în rețea. Util pentru televizoare Smart sau playere fără addon Kodi. Consumă puține resurse suplimentare."

msgctxt "#32051"
msgid "DLNA friendly name"
msgstr "Nume prietenos DLNA"

msgctxt "#32151"
msgid "Name TorrServer appears as in the DLNA device list. Change if you have multiple TorrServer instances on the network."
msgstr "Numele sub care apare TorrServer în lista de dispozitive DLNA. Schimbați dacă aveți mai multe instanțe TorrServer în rețea."

msgctxt "#32005"
msgid "Authentication"
msgstr "Autentificare"

msgctxt "#32060"
msgid "Enable HTTP authentication"
msgstr "Activează autentificarea HTTP"

msgctxt "#32160"
msgid "Protects TorrServer with username and password. Recommended ON if TorrServer is accessible from outside the local network."
msgstr "Protejează TorrServer cu nume de utilizator și parolă. Recomandat ON dacă TorrServer este accesibil din afara rețelei locale."

msgctxt "#32061"
msgid "Username"
msgstr "Nume utilizator"

msgctxt "#32161"
msgid "Username for HTTP Basic authentication. Minimum 4 characters recommended."
msgstr "Numele de utilizator pentru autentificarea HTTP Basic. Minim 4 caractere recomandat."

msgctxt "#32062"
msgid "Password"
msgstr "Parolă"

msgctxt "#32162"
msgid "Password for HTTP Basic authentication. Use a strong password if TorrServer is exposed to the internet."
msgstr "Parola pentru autentificarea HTTP Basic. Folosiți o parolă puternică dacă TorrServer este expus pe internet."

# ============= NOI INTRĂRI pentru v1.0.0 =============
msgctxt "#32094"
msgid "Delete backup file"
msgstr "Șterge fișierul de rezervă"

msgctxt "#32095"
msgid "Removes the .bak backup file created during binary updates. Useful to free up space."
msgstr "Șterge fișierul .bak creat la actualizarea binarului. Util pentru eliberarea spațiului."

msgctxt "#32096"
msgid "Reset all settings to default"
msgstr "Resetează toate setările la implicit"

msgctxt "#32097"
msgid "Restores all addon settings to their factory default values. The service will restart."
msgstr "Restaurează toate setările addon-ului la valorile implicite din fabrică. Serviciul se va reporni."