# ── Cache help texts ─────────────────────────────────────────────────
msgctxt "#32120"
msgid "Recommended: 64MB for RPi3/low RAM devices, 256MB for RPi4, 512MB+ for PC/NUC. Higher values reduce re-buffering."
msgstr ""

msgctxt "#32121"
msgid "ON = fast RAM cache (recommended). OFF = disk cache, slower but saves RAM. Useful on devices with under 1GB free RAM."
msgstr ""

msgctxt "#32122"
msgid "Percentage of cache preloaded ahead. 95% recommended for stable streaming. Lower to 50-70% if torrent starts slowly."
msgstr ""

msgctxt "#32123"
msgid "Percentage of cache filled before playback starts. 50% balances wait time and stability. Increase on slow connections."
msgstr ""

