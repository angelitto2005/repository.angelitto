<?xml version="1.0" encoding="UTF-8"?>
<settings>

  <category label="[B][COLOR orange]Backup Location[/COLOR][/B]">
    <setting id="backup_path"
             type="folder"
             label="[B][COLOR orange]Backup / Restore folder[/COLOR][/B]"
             default=""
             source=""
             option="writeable"/>
  </category>

  <category label="Backup - [B][COLOR blue]XML Files[/COLOR][/B]">
    <setting id="bkp_favourites"
             type="bool"
             label="Backup: [B][COLOR blue]favourites.xml[/COLOR][/B]"
             default="true"/>

    <setting id="bkp_guisettings"
             type="bool"
             label="Backup: [B][COLOR blue]guisettings.xml[/COLOR][/B]"
             default="true"/>

    <setting id="bkp_sources"
             type="bool"
             label="Backup: [B][COLOR blue]sources.xml[/COLOR][/B]"
             default="true"/>

    <setting id="bkp_passwords"
             type="bool"
             label="Backup: [B][COLOR blue]passwords.xml[/COLOR][/B]"
             default="true"/>

    <setting id="bkp_mediasources"
             type="bool"
             label="Backup: [B][COLOR blue]mediasources.xml[/COLOR][/B]"
             default="true"/>

    <setting id="bkp_advancedsettings"
             type="bool"
             label="Backup: [B][COLOR blue]advancedsettings.xml[/COLOR][/B]"
             default="false"/>

    <setting id="bkp_genxml"
             type="bool"
             label="Backup: [B]userdata/keymaps/[COLOR blue]gen.xml[/COLOR][/B]"
             default="false"/>
			 
  </category>

  <category label="Backup - [B][COLOR blue]Folders[/COLOR][/B]">
    <setting id="bkp_addon_data"
             type="bool"
             label="Backup: [B][COLOR blue]userdata/addon_data/[/COLOR][/B] (addons settings)"
             default="true"/>

    <setting id="bkp_playlists"
             type="bool"
             label="Backup: [B][COLOR blue]userdata/playlists/[/COLOR][/B]"
             default="true"/>
  </category>

  <category label="Backup - [B][COLOR blue]Database[/COLOR][/B]">
    <setting id="bkp_myvideos_db"
             type="bool"
             label="Backup: [B][COLOR blue]MyVideos*.db[/COLOR][/B] (all versions)"
             default="true"/>

    <setting id="bkp_addons_db"
             type="bool"
             label="Backup: [B][COLOR blue]Addons*.db[/COLOR][/B]"
             default="true"/>

    <setting id="bkp_viewmodes_db"
             type="bool"
             label="Backup: [B][COLOR blue]ViewModes*.db[/COLOR][/B]"
             default="true"/>
  </category>

  <category label="[B][COLOR red]Cleaning Options[/COLOR][/B]">
    <setting id="clean_packages"
             type="bool"
             label="Clean: [B][COLOR red]addons/packages/[/COLOR][/B] (downloaded addon zips)"
             default="true"/>

    <setting id="clean_addons_temp"
             type="bool"
             label="Clean: [B][COLOR red]addons/temp/[/COLOR][/B] (temporary addon files)"
             default="true"/>

    <setting id="clean_cache"
             type="bool"
             label="Clean: [B][COLOR red]cache/[/COLOR][/B] (Kodi cache - Windows/Linux)"
             default="true"/>

    <setting id="clean_temp"
             type="bool"
             label="Clean: [B][COLOR red]temp/[/COLOR][/B] (Kodi temp - Android)"
             default="true"/>

    <setting id="clean_thumbnails"
             type="bool"
             label="Clean: [B][COLOR red]userdata/Thumbnails/[/COLOR][/B] (image cache)"
             default="true"/>

    <setting id="clean_textures_db"
             type="bool"
             label="Clean: [B][COLOR red]Textures*.db[/COLOR][/B] (thumbnail database)"
             default="true"/>
  </category>

</settings>