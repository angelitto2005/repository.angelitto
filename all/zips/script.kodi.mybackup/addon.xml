<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.kodi.mybackup" name="[B][COLOR cyan]My Custom [B][COLOR gray]Backup[/COLOR][/B]" version="1.0.5" provider-name="[B][COLOR FF6AFB92]Angelitto[/COLOR][/B]">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Backup and Restore specific Kodi files</summary>
        <description lang="en">Salveaza si restaureaza doar addons si fisiere esentiale din userdata.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>