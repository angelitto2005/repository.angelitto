<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.torrserver"
       name="[B][COLOR orange]Torr[COLOR gray]Server[/COLOR][/B]"
       version="0.0.4b"
       provider-name="[B][COLOR orange]BB[/COLOR][/B]">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.service"
             library="service.py"
             start="startup"/>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">TorrServer background service</summary>
    <description lang="en">[B][COLOR FF009900]Starts TorrServer automatically at boot. Configurable from Kodi settings. Supports Windows, Linux, CoreELEC/LibreELEC and Android.[/COLOR][/B]</description>
    <platform>all</platform>
    <license>GPL-2.0</license>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
